rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Configuración de chat widget (config.html, commands.html) ──────────────
    match /usuarios/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.canal is string
        && request.resource.data.canal.size() > 0
        && request.resource.data.canal.size() <= 40
        && request.resource.data.color is string
        && request.resource.data.color.matches('^#[0-9a-fA-F]{6}$')
        && (
          !('colorRecuadro' in request.resource.data)
          || request.resource.data.colorRecuadro.matches('^#[0-9a-fA-F]{6}$')
        )
        && (
          !('grosorBorde' in request.resource.data)
          || (request.resource.data.grosorBorde is int && request.resource.data.grosorBorde >= 2 && request.resource.data.grosorBorde <= 12)
        )
        && (
          !('opacidadRecuadro' in request.resource.data)
          || (request.resource.data.opacidadRecuadro is int && request.resource.data.opacidadRecuadro >= 10 && request.resource.data.opacidadRecuadro <= 100)
        )
        && (
          !('customCssMode' in request.resource.data)
          || request.resource.data.customCssMode in ['url', 'file']
        )
        && (
          !('customCssUrl' in request.resource.data)
          || (
            request.resource.data.customCssUrl is string
            && request.resource.data.customCssUrl.size() <= 600
            && request.resource.data.customCssUrl.matches('^$|^https?://.+')
          )
        )
        && (
          !('customCssContent' in request.resource.data)
          || (
            request.resource.data.customCssContent is string
            && request.resource.data.customCssContent.size() <= 200000
          )
        );
    }

    // ── Tokens de Twitch – solo el dueño (uid match) puede escribir ────────────
    match /twitchBots/{channel} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.accessToken is string
        && request.resource.data.accessToken.size() > 0
        && request.resource.data.channel is string
        && request.resource.data.channel.size() > 0;
      allow update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ── Canjes configurados – solo el dueño puede escribir/eliminar ───────────
    match /channelPointRedeems/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.canal is string
        && request.resource.data.canal.size() > 0
        && request.resource.data.canal.size() <= 40;
      allow update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ── Alertas y efectos en vivo – cualquier usuario autenticado puede escribir
    // (incluye anónimos del overlay en OBS)
    match /liveAlerts/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.canal is string
        && request.resource.data.canal.size() > 0;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    match /liveEffects/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.canal is string
        && request.resource.data.canal.size() > 0;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ── Presencia del overlay en OBS (heartbeat + estado EventSub) ────────────
    match /overlayPresence/{channel} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.canal is string
        && request.resource.data.canal == channel;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.canal is string
        && request.resource.data.canal == channel;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ── Resto de colecciones (comandos, bots, etc.) – requiere autenticación ───
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
